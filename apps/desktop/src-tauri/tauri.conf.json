{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Setup OS",
  "version": "0.0.0",
  "identifier": "ai.setup-os.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Setup OS",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../../setup_os/*.py": "engine/setup_os/",
      "../../../examples/*": "engine/examples/"
    }
  }
}
